generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  email            String             @unique
  password         String?
  bio              String?
  createdAt        DateTime           @default(now())

  oauthAccounts    OAuthAccount[]
  likeReviews      LikeReview[]
  reviews          Review[]
  userGames        UserGameRelation[]
  receivedRequests UserUserRelation[] @relation("receivedRequests")
  sentRequests     UserUserRelation[] @relation("sentRequests")
}

model OAuthAccount {
  id             Int      @id @default(autoincrement())
  userId         Int
  provider       OAuthProvider
  providerUserId String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model Game {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  imageSmall  String
  imageBig    String
  description String
  releaseDate DateTime
  updateDate  DateTime
  developer   String?
  publisher   String?
  rating      Float
  reviews     Review[]
  userGames   UserGameRelation[]
  modes       GameMode[]         @relation("GameToMode")
  genres      Genre[]            @relation("GameToGenre")
  platforms   Platform[]         @relation("GameToPlatform")
}

model Platform {
  id        Int                @id @default(autoincrement())
  name      String             @unique
  reviews   Review[]
  games     Game[]             @relation("GameToPlatform")
}

model GameMode {
  id        Int                @id @default(autoincrement())
  name      String             @unique
  games     Game[]             @relation("GameToMode")
}

model Genre {
  id    Int                    @id @default(autoincrement())
  name  String                 @unique
  games Game[]                 @relation("GameToGenre")
}

model Review {
  id          Int          @id @default(autoincrement())
  userId      Int
  gameId      Int
  review      String?
  rating      Int
  likeReviews LikeReview[]
  platformId  Int?
  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform    Platform?     @relation(fields: [platformId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId])
}

model UserGameRelation {
  id         Int        @id @default(autoincrement())
  userId     Int
  gameId     Int
  gameStatus GameStatus?
  favorite   Boolean    @default(false)
  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model LikeReview {
  id       Int    @id @default(autoincrement())
  userId   Int
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
}

model UserUserRelation {
  id           Int              @id @default(autoincrement())
  senderId     Int
  receiverId   Int
  friendStatus FriendshipStatus
  receiver     User             @relation("receivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender       User             @relation("sentRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

enum GameStatus {
  WANT_TO_PLAY
  PLAYING
  COMPLETED
  DNF
}

enum FriendshipStatus {
  PENDING
  FRIENDS
}

enum OAuthProvider {
  GOOGLE
  FT
}
