generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  name             String
  bio              String?
  likeReviews      LikeReview[]
  reviews          Review[]
  usersGames       UserGameRelation[]
  receivedRequests UserUserRelation[] @relation("receivedRequests")
  sentRequests     UserUserRelation[] @relation("sentRequests")
}

model Game {
  id          Int                @id @default(autoincrement())
  title       String
  image       String
  description String
  releaseDate DateTime
  updateDate  DateTime
  developer   String
  publisher   String
  mode        String
  rating      Int
  reviews     Review[]
  userGames   UserGameRelation[]
  genres      Genre[]            @relation("GameToGenre")
  platform    Platform[]         @relation("GameToPlatform")
}

model Platform {
  id        Int                @id @default(autoincrement())
  platform  String
  userGames UserGameRelation[]
  games     Game[]             @relation("GameToPlatform")
}

model Genre {
  id    Int    @id @default(autoincrement())
  name  String
  games Game[] @relation("GameToGenre")
}

model Review {
  id          Int          @id @default(autoincrement())
  userId      Int
  gameId      Int
  review      String
  rating      Int
  likeReviews LikeReview[]
  game        Game         @relation(fields: [gameId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
}

model UserGameRelation {
  id         Int        @id @default(autoincrement())
  userId     Int
  gameId     Int
  status     GameStatus
  favorite   Boolean    @default(false)
  platformId Int
  game       Game       @relation(fields: [gameId], references: [id])
  platform   Platform   @relation(fields: [platformId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

model LikeReview {
  id       Int    @id @default(autoincrement())
  userId   Int
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id])
  user     User   @relation(fields: [userId], references: [id])
}

model UserUserRelation {
  id       Int              @id @default(autoincrement())
  userId   Int
  friendId Int
  status   FriendshipStatus
  friend   User             @relation("receivedRequests", fields: [friendId], references: [id])
  user     User             @relation("sentRequests", fields: [userId], references: [id])
}

enum GameStatus {
  WANT_TO_PLAY
  PLAYING
  COMPLETED
  DNF
}

enum FriendshipStatus {
  NONE
  PENDING
  FRIENDS
}
