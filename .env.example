BACK_PORT="4243"
DB_NAME="goodplays_db"
DB_USER="postgres"
DB_PASSWORD="password"
DATABASE_URL="postgresql://postgres:password@postgres_db:5432/goodplays_db"
NODE_ENV="development"
# To generate a new JWT_SECRET to your environment run in terminal: openssl rand -base64 32
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"

# "change-me" for google will be shared with you in Discord
GOOGLE_CLIENT_ID="change-me" 
GOOGLE_CLIENT_SECRET="change-me" 
GOOGLE_CALLBACK_URL="http://localhost:4243/auth/google/callback"